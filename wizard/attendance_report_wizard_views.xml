<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_attendance_report_wizard_form" model="ir.ui.view">
        <field name="name">attendance.report.wizard.form</field>
        <field name="model">attendance.report.wizard</field>
        <field name="arch" type="xml">
            <form string="Attendance XLSX Report">
                <group>
                    <group string="Date Range">
                        <field name="date_from"/>
                        <field name="date_to"/>
                    </group>
                    <group string="Filters">
                        <field name="employee_ids" widget="many2many_tags"/>
                        <field name="department_ids" widget="many2many_tags"/>
                    </group>
                </group>
                <group string="Download" invisible="not file_data">
                    <field name="file_data" filename="filename" widget="binary" string="XLSX File"/>
                    <field name="filename" invisible="True"/>
                </group>
                <footer>
                    <button name="action_generate" string="Generate &amp; Download"
                            type="object" class="btn-primary"/>
                    <button string="Close" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_attendance_report_wizard" model="ir.actions.act_window">
        <field name="name">Attendance XLSX Report</field>
        <field name="res_model">attendance.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem
        id="menu_attendance_report_xlsx"
        name="Attendance XLSX Report"
        parent="hr_attendance.menu_hr_attendance_root"
        action="action_attendance_report_wizard"
        sequence="50"
        groups="hr_attendance.group_hr_attendance_manager"/>
</odoo>